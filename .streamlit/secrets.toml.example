# Streamlit secrets template.
#
# LOCAL: this app reads config from a .env file (see .env.example), so you do
# NOT need this file to run locally.
#
# STREAMLIT COMMUNITY CLOUD: there is no .env on the server. Instead, open your
# app's Settings -> Secrets in the Streamlit Cloud dashboard and paste the four
# key/value pairs below (with your real values). Streamlit exposes top-level
# secrets as environment variables, which is how os.environ[...] in app/llm.py
# and app/db.py picks them up.
#
# Do NOT commit a filled-in secrets.toml - it is gitignored for that reason.

GROQ_API_KEY = "your-groq-key"
GOOGLE_API_KEY = "your-gemini-key"
TAVILY_API_KEY = "your-tavily-key"
DATABASE_URL = "your-neon-postgres-url"
